        upper(trim(city))                       as city_name,
        trim(home_locality)                     as home_locality,
        UPPER(trim(home_store_id))              as home_store_id,
        cast(is_pass_member as bool)            as is_pass_member, 
        cast(signup_date    as date)            as signup_date,

