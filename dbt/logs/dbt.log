        round(
            cast(quantity as numeric) * cast(unit_price as numeric)
            * (1 - coalesce(cast(0 as numeric), 0) / 100),
            2
        )                               as line_revenue,
        current_timestamp()             as _dbt_loaded_at

    from source
    where order_item_id is not null and order_id is not null
)

