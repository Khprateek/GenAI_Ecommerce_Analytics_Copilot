            ('store',       'Physical Store',   'Offline',  'Direct'),
            ('marketplace', 'Marketplace',      'Digital',  'Partner'),
            ('social',      'Social Commerce',  'Digital',  'Partner'),
            ('email',       'Email Campaign',   'Digital',  'Marketing')
    ) as t(channel_code, channel_name, channel_type, channel_category)
),

final as (
    select
        to_hex(md5(cast(coalesce(cast(channel_code as string), '_dbt_utils_surrogate_key_null_') as string))) as channel_sk,
        channel_code,
        channel_name,
        channel_type,
        channel_category,
        case channel_type
            when 'Digital' then true
            else false
        end as is_digital
    from channels
)

select * from final
    );
  
