  create or replace view `genai-copilot-enterprisedata`.`staging_staging`.`stg_products`
  OPTIONS()
  as with source as (
    select * from `genai-copilot-enterprisedata`.`raw`.`products`
),

cleaned as (
    select
        cast(product_id     as string)  as product_id,
        trim(product_name)              as product_name,
        trim(category)                  as category,
        trim(sub_category)              as sub_category,
        trim(brand)                     as brand,

        cast(cost_price     as numeric) as cost_price_usd,
        cast(retail_price   as numeric) as retail_price_usd,

        -- derived: margin %
        round(
            safe_divide(
                cast(retail_price as numeric) - cast(cost_price as numeric),
                cast(retail_price as numeric)
            ) * 100,
            2
        )                               as margin_pct,

        cast(is_active      as boolean) as is_active,
        current_timestamp()             as _dbt_loaded_at

    from source
    where product_id is not null
)

select * from cleaned;


